  "info": {
    "_postman_id": "2c3252d6-e98a-49d1-b45a-2f9c779184db",
    "name": "LogRocket GraphQL API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The LogRocket GraphQL API allows developers to query session replay and analytics data using GraphQL. It provides a flexible query interface for retrieving session information, user activity, error details, and performance metrics. Developers can use this API to build custom dashboards, integrate session data into internal tools, and perform advanced filtering and aggregation of LogRocket monitoring data.\n\nContact Support:\n Name: LogRocket Support",
      "type": "text/plain"
    }
