      "name": "Highlights",
      "description": {
        "content": "Access Galileo AI-generated session highlights and summaries.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "8e52334f-49e1-4f46-b199-a9a146a40cf8",
          "name": "Request Galileo AI session highlights",
          "request": {
            "name": "Request Galileo AI session highlights",
            "description": {
              "content": "Initiates a request for Galileo AI to generate session highlights and summaries. You can specify a user by email or user ID, and optionally limit the time range. The response includes a request ID that can be used to poll for results. Optionally provide a webhook URL to receive results via POST when they are ready.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "orgs",
                ":orgId",
                "apps",
                ":appId",
                "highlights",
                ""
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "orgId",
                  "description": "(Required) The organization identifier found in the LogRocket dashboard URL."
                },
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "appId",
                  "description": "(Required) The application or project identifier found in the LogRocket dashboard URL."
                }
              ]
            },
            "header": [
