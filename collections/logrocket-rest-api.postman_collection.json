  "info": {
    "_postman_id": "4846bf9e-c29b-4152-aaad-9b60dccf45b9",
    "name": "LogRocket REST API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The LogRocket REST API provides programmatic access to LogRocket session replay and monitoring data. It enables developers to manage user identification by sending demographic and engagement data via PUT requests to contextualize user behavior. The API also supports retrieving session highlights and exported session data. All endpoints require an API access key available from the LogRocket dashboard under Settings.\n\nContact Support:\n Name: LogRocket Support",
      "type": "text/plain"
    }
  }
